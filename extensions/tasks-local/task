#!/usr/bin/env node
// tasks-local CLI — manage local .tasks/ folders
// Usage:
//   node task list                      # list all tasks
//   node task create <title>             # create a new task
//   node task show <id>                  # show task details
//   node task done <id>                  # mark task as done
//   node task progress <id>              # mark task as in-progress
//
// Tasks live in .tasks/<id>/task.md with frontmatter.

const fs = require('fs')
const path = require('path')

const TASKS_DIR = path.join(process.cwd(), '.tasks')

function die(msg) { process.stderr.write('error: ' + msg + '\n'); process.exit(1) }

function taskDir(id) { return path.join(TASKS_DIR, id) }
function taskFile(id) { return path.join(taskDir(id), 'task.md') }

function nextId() {
  if (!fs.existsSync(TASKS_DIR)) return 'T-001'
  const dirs = fs.readdirSync(TASKS_DIR).filter(d => /^T-\d+$/.test(d))
  if (dirs.length === 0) return 'T-001'
  const nums = dirs.map(d => parseInt(d.slice(2), 10))
  return 'T-' + String(Math.max(...nums) + 1).padStart(3, '0')
}

function parseTask(id) {
  const file = taskFile(id)
  if (!fs.existsSync(file)) die(`task ${id} not found`)
  const content = fs.readFileSync(file, 'utf8')
  const m = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/)
  if (!m) die(`invalid task.md in ${id}`)
  const frontmatter = {}
  for (const line of m[1].split('\n')) {
    const [k, ...v] = line.split(':')
    frontmatter[k.trim()] = v.join(':').trim()
  }
  return { frontmatter, body: m[2].trim() }
}

function writeTask(id, frontmatter, body) {
  const dir = taskDir(id)
  fs.mkdirSync(dir, { recursive: true })
  const fm = Object.entries(frontmatter).map(([k, v]) => `${k}: ${v}`).join('\n')
  fs.writeFileSync(taskFile(id), `---\n${fm}\n---\n\n${body}\n`)
}

// ─── Commands ──────────────────────────────────────────────────

function cmdList() {
  if (!fs.existsSync(TASKS_DIR)) return
  const dirs = fs.readdirSync(TASKS_DIR).filter(d => /^T-\d+$/.test(d)).sort()
  for (const id of dirs) {
    const t = parseTask(id)
    const status = t.frontmatter.status || 'todo'
    const icon = status === 'done' ? '✓' : status === 'in-progress' ? '▶' : '○'
    console.log(`${icon} ${id}  [${status}]  ${t.frontmatter.title || 'untitled'}`)
  }
}

function cmdCreate(title) {
  const id = nextId()
  writeTask(id, { id, title, status: 'todo', created: new Date().toISOString().slice(0, 10) }, title)
  console.log(`created: ${id} — ${title}`)
}

function cmdShow(id) {
  const t = parseTask(id)
  console.log(`ID:     ${id}`)
  console.log(`Title:  ${t.frontmatter.title}`)
  console.log(`Status: ${t.frontmatter.status || 'todo'}`)
  console.log(`---`)
  console.log(t.body)
}

function cmdDone(id) {
  const t = parseTask(id)
  t.frontmatter.status = 'done'
  t.frontmatter.updated = new Date().toISOString().slice(0, 10)
  writeTask(id, t.frontmatter, t.body)
  console.log(`${id} marked as done`)
}

function cmdProgress(id) {
  const t = parseTask(id)
  t.frontmatter.status = 'in-progress'
  t.frontmatter.updated = new Date().toISOString().slice(0, 10)
  writeTask(id, t.frontmatter, t.body)
  console.log(`${id} marked as in-progress`)
}

// ─── Main ────────────────────────────────────────────────────────

const [cmd, ...args] = process.argv.slice(2)

switch (cmd) {
  case 'list':    cmdList(); break
  case 'create':  cmdCreate(args.join(' ')); break
  case 'show':    cmdShow(args[0]); break
  case 'done':    cmdDone(args[0]); break
  case 'progress': cmdProgress(args[0]); break
  default:
    console.error('Usage: node task list|create|show|done|progress [args]')
    process.exit(1)
}
