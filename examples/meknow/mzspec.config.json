{
  "$schema": "../../mzspec.config.schema.json",
  "mzspecVersion": "0.1.0",
  "openspec": {
    "changesDir": "openspec/changes",
    "specsDir": "openspec/specs",
    "archivePattern": "YYYY-MM-DD-{change}",
    "evidenceDir": "openspec/changes/{change}/evidence"
  },
  "git": {
    "base": "main",
    "branchPrefix": "feat/",
    "specBranchPrefix": "spec/",
    "changelog": "CHANGELOG.md"
  },
  "handoffDir": ".handoff/{change}",
  "toolchains": {
    "go": {
      "dirs": [
        "packages/mello-sdk",
        "packages/mezon-go-sdk-turbo",
        "packages/event-core",
        "apps/worker-mello",
        "apps/worker-mezon-go",
        "archive/backend-go"
      ],
      "gates": [
        { "name": "build", "cmd": "(cd {dir} && go build ./...)" },
        { "name": "vet", "cmd": "(cd {dir} && go vet ./...)" },
        { "name": "test", "cmd": "(cd {dir} && go test -race ./...)" },
        { "name": "coverage", "cmd": "(cd {dir} && go test -race -coverprofile=cover.out ./... && go tool cover -func=cover.out | tail -1)" }
      ]
    },
    "py": {
      "dirs": [
        "packages/rag-core",
        "packages/agent-core",
        "packages/arag-core",
        "packages/ingest-core",
        "packages/llm-transport",
        "packages/connector-core",
        "packages/agent-sdk",
        "packages/agent-harness",
        "apps/backend",
        "apps/worker-ingest",
        "apps/worker-retrieve",
        "apps/worker-task",
        "apps/worker-local",
        "apps/worker-stub",
        "apps/worker-filesystem",
        "apps/worker-jira",
        "apps/worker-slack",
        "apps/worker-github",
        "apps/worker-webhook",
        "apps/kb-mcp",
        "apps/cli"
      ],
      "gates": [
        { "name": "lint", "cmd": "uv --directory {dir} run ruff check ." },
        { "name": "format", "cmd": "uv --directory {dir} run ruff format --check ." },
        { "name": "typecheck", "cmd": "uv --directory {dir} run pyright" },
        { "name": "test", "cmd": "uv --directory {dir} run python -m pytest -q" },
        { "name": "coverage", "cmd": "uv --directory {dir} run python -m pytest -q --cov --cov-report=term-missing" }
      ]
    },
    "ts": {
      "dirs": ["apps/portal"],
      "gates": [
        { "name": "typecheck", "cmd": "(cd {dir} && pnpm typecheck)" },
        { "name": "lint", "cmd": "(cd {dir} && pnpm lint)" },
        { "name": "test", "cmd": "(cd {dir} && pnpm test)" }
      ]
    }
  },
  "bench": {
    "prefix": "benchmarks/",
    "dir": "benchmarks",
    "alsoWhenToolchains": ["py"],
    "gates": [{ "name": "free-ladder", "cmd": "bash benchmarks/ci-free-gates.sh" }]
  },
  "metaPrefixes": ["openspec/", "docs/", ".claude/", ".github/"],
  "always": [{ "name": "openspec-validate", "cmd": "openspec validate \"<change>\" --strict" }],
  "migration": {
    "pattern": "(^|/)(migrations|alembic)/",
    "gate": {
      "name": "migration",
      "cmd": "uv --directory apps/backend run alembic upgrade head  # needs DATABASE_URL (pgvector)"
    }
  },
  "gatesDir": "benchmarks/gates",
  "templatesDir": "openspec/templates",
  "customGates": [],
  "taskSources": [
    { "name": "local", "type": "local-folder", "enabled": true, "config": { "path": ".tasks" } },
    { "name": "github", "type": "gh-issues", "enabled": false, "config": { "repo": "mezonai/mezon-bot-ai", "label": "backlog" } },
    { "name": "mello", "type": "mello-cli", "enabled": false, "config": { "board": "<board-id>", "column": "Todo" } }
  ],
  "taskStatusMap": {
    "gh-issues": { "in-progress": ["+in-progress", "-in-review"], "in-review": ["+in-review", "-in-progress"], "done": ["state:closed"] },
    "mello-cli": { "columns": { "todo": "Todo", "in-progress": "In Progress", "in-review": "In Review", "done": "Done" } }
  },
  "invariants": [
    "Multi-tenant: tenant_id on every table, query, cache key, and log line; cross-tenant joins are bugs",
    "ACL is server-side inside retrieve_kb; caller identity inherited, never trusted from the model",
    "Citations mandatory: any answer-producing path refuses rather than emit ungrounded claims; filter stage has refuse_if: no_citations",
    "temperature == 0 on every synthesize, cite, and filter stage",
    "Versions are append-only (BotVersion, KBVersion, golden sets, traces)",
    "Compression invariant: only memo_schema_ref-shaped objects cross stage boundaries; raw KB chunks never leave a sub-agent",
    "MCP is the internal tool boundary; no LangChain/LangGraph/Haystack/LlamaIndex",
    "Cache keys include an ACL-cohort hash",
    "OpenAPI is the API contract; portal types are generated, never hand-written"
  ]
}
